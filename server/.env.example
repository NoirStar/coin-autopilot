# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# 업비트 API (현물)
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# OKX API (선물)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# 서버
PORT=3001

# Vercel 자동 동기화 (Quick Tunnel URL -> VITE_API_URL)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# 조직 프로젝트면 필요 (개인 계정이면 비워둠)
VERCEL_TEAM_ID=
# preview 또는 production
VERCEL_ENV=production
# 기본값: VITE_API_URL
VERCEL_VAR_NAME=VITE_API_URL

# 실전매매 (기본 비활성. 가상매매 검증 후 활성화)
LIVE_TRADING=false
# OKX 테스트넷 (true면 실제 자금 사용 안 함)
OKX_TESTNET=true
